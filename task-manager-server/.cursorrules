## Type Definitions

### Entity Types
```typescript
// types/entity.ts

// Enums as union types
export type EntityStatus = 'active' | 'inactive' | 'archived';
export type EntityType = 'type_a' | 'type_b';

// Main entity interface
export interface Entity {
  id: number;
  name: string;
  status: EntityStatus;
  type: EntityType;
  created_at: string;
  updated_at: string;
}

// With joined data
export interface EntityWithDetails extends Entity {
  related_name?: string;
  assignees?: User[];
}

// DTOs (Data Transfer Objects)
export interface CreateEntityDTO {
  name: string;
  type: EntityType;
  description?: string;
}

export interface UpdateEntityDTO {
  name?: string;
  type?: EntityType;
  description?: string;
}

// Filter types
export interface EntityFilter {
  status?: EntityStatus;
  type?: EntityType;
  search?: string;
}
```

### Common Types
```typescript
// types/common.ts

export interface AuthenticatedRequest extends Request {
  user?: {
    id: number;
    email: string;
    role: string;
    name: string;
    department_id: number | null;
  };
}

export interface PaginationParams {
  page: number;
  limit: number;
  offset: number;
}

export interface PaginatedResponse<T> {
  data: T[];
  pagination: {
    page: number;
    limit: number;
    total: number;
    totalPages: number;
  };
}
```

