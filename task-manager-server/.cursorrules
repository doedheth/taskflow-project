## Route Pattern (v2 - Slim Routes)

```typescript
// routes/v2/entities.ts
import { Router } from 'express';
import { body } from 'express-validator';
import { auth, managerOrAdmin } from '../../middleware/auth';
import { entityController } from '../../controllers/EntityController';

const router = Router();

// Validation middleware
const createValidation = [
  body('title').notEmpty().withMessage('Title is required'),
  body('type').isIn(['a', 'b']).withMessage('Invalid type'),
];

// Routes - delegate to controller
router.get('/', auth, entityController.getAll);
router.get('/:id', auth, entityController.getById);
router.post('/', auth, managerOrAdmin, createValidation, entityController.create);
router.put('/:id', auth, managerOrAdmin, entityController.update);
router.delete('/:id', auth, managerOrAdmin, entityController.delete);

// Custom actions
router.post('/:id/start', auth, entityController.start);

export default router;
```

