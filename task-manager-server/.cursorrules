# TaskFlow Backend Rules - Node.js/Express/TypeScript/SQLite

## Project Overview
TaskFlow Server adalah backend API untuk sistem manajemen proyek dan maintenance pabrik thermoforming.
- **Stack**: Node.js, Express, TypeScript, SQLite (sql.js)
- **Architecture**: OOP with Repository, Service, Controller pattern
- **Authentication**: JWT
- **Bahasa Code**: English (comments, variables, functions)

---

## Architecture Overview (OOP Pattern)

```
src/
├── controllers/          # HTTP request handlers
│   ├── BaseController.ts # Abstract base controller
│   └── WorkOrderController.ts
├── services/             # Business logic layer
│   ├── BaseService.ts    # Abstract base service with error classes
│   └── WorkOrderService.ts
├── models/               # Data access layer (Repository pattern)
│   ├── BaseRepository.ts # Abstract base repository
│   └── WorkOrderRepository.ts
├── routes/
│   ├── v2/              # New OOP routes (slim)
│   │   └── workOrders.ts
│   └── workOrders.ts    # Legacy routes (for backward compatibility)
├── types/               # TypeScript interfaces
│   ├── common.ts        # Shared types
│   └── workOrder.ts     # Entity-specific types
├── middleware/          # Auth, validation, error handling
├── database/            # DB connection, migrations
└── index.ts
```

### Layer Responsibilities

| Layer | Responsibility | Example |
|-------|---------------|---------|
| **Controller** | HTTP handling, request parsing, response formatting | `WorkOrderController.ts` |
| **Service** | Business logic, validation, orchestration | `WorkOrderService.ts` |
| **Repository** | Data access, SQL queries, CRUD operations | `WorkOrderRepository.ts` |
| **Types** | TypeScript interfaces and DTOs | `workOrder.ts` |

---

## File Naming Conventions

| Type | Convention | Example |
|------|------------|---------|
| Controllers | PascalCase + Controller | `WorkOrderController.ts` |
| Services | PascalCase + Service | `WorkOrderService.ts` |
| Repositories | PascalCase + Repository | `WorkOrderRepository.ts` |
| Types | PascalCase (interface) | `WorkOrder`, `CreateWorkOrderDTO` |
| Routes | camelCase | `workOrders.ts` |
| Database Tables | snake_case plural | `work_orders` |

---

## Repository Pattern

### Base Repository
```typescript
import { BaseRepository } from './BaseRepository';

export class EntityRepository extends BaseRepository<Entity, CreateDTO, UpdateDTO> {
  constructor() {
    super('table_name'); // Table name
  }

  // Implement abstract methods
  create(data: CreateDTO, userId?: number): Entity {
    const result = this.execute(
      'INSERT INTO table_name (col1, col2) VALUES (?, ?)',
      [data.col1, data.col2]
    );
    return this.findById(Number(result.lastInsertRowid))!;
  }

  update(id: number, data: UpdateDTO): Entity | null {
    // ... implementation
  }

  // Custom queries
  findByCustomField(value: string): Entity[] {
    return this.query('SELECT * FROM table_name WHERE field = ?', [value]);
  }
}

// Export singleton
export const entityRepository = new EntityRepository();
```

### Repository Methods (inherited)
```typescript
// Query methods
findAll(pagination?)        // Get all records
findById(id)               // Get by ID
findBy(field, value)       // Find by field
findOneBy(field, value)    // Find one by field
count(where?, params?)     // Count records
exists(id)                 // Check existence

// Mutation methods
create(data, userId?)      // Create record (abstract)
update(id, data, userId?)  // Update record (abstract)
delete(id)                 // Delete record

// Transaction methods
beginTransaction()         // Start transaction
commit()                   // Commit
rollback()                 // Rollback
transaction(callback)      // Execute in transaction

// Protected helpers
query<T>(sql, params)      // Execute SELECT, return array
queryOne<T>(sql, params)   // Execute SELECT, return one
execute(sql, params)       // Execute INSERT/UPDATE/DELETE
```

---

## Service Pattern

### Base Service
```typescript
import { BaseService, ValidationError, NotFoundError } from './BaseService';

export class EntityService extends BaseService<Entity, CreateDTO, UpdateDTO> {
  constructor(repository: EntityRepository) {
    super(repository);
  }

  // Override validation hooks
  protected validateCreate(data: CreateDTO): void {
    const errors = [];
    if (!data.requiredField) {
      errors.push({ field: 'requiredField', message: 'Field is required' });
    }
    if (errors.length > 0) {
      throw new ValidationError('Validation failed', errors);
    }
  }

  // Custom business methods
  customBusinessLogic(id: number): Entity {
    const entity = this.repository.findById(id);
    if (!entity) throw new NotFoundError('Entity not found');
    
    // Business logic here
    return entity;
  }
}

// Export singleton
export const entityService = new EntityService(entityRepository);
```

### Error Classes
```typescript
import {
  ServiceError,      // Base error (500)
  NotFoundError,     // 404
  ValidationError,   // 400 with field errors
  UnauthorizedError, // 401
  ForbiddenError,    // 403
  ConflictError      // 409
} from '../services/BaseService';

// Usage
throw new NotFoundError('Work order not found');
throw new ValidationError('Validation failed', [
  { field: 'title', message: 'Title is required' }
]);
throw new ForbiddenError('Access denied');
```

---

## Controller Pattern

### Base Controller
```typescript
import { BaseController } from './BaseController';

export class EntityController extends BaseController<Entity, CreateDTO, UpdateDTO> {
  constructor(service: EntityService) {
    super(service);
  }

  // Standard CRUD handlers are inherited:
  // getAll, getById, create, update, delete

  // Custom handlers
  customAction = (req: Request, res: Response): void => {
    try {
      const id = parseInt(req.params.id);
      const userId = this.getUserId(req);
      const result = this.service.customMethod(id, userId);
      this.success(res, result);
    } catch (error) {
      this.handleError(res, error, 'Custom action');
    }
  };
}

// Export singleton
export const entityController = new EntityController(entityService);
```

### Controller Helper Methods
```typescript
// Request helpers
getUser(req)              // Get authenticated user
getUserId(req)            // Get user ID
hasRole(req, roles[])     // Check user role
getPagination(req)        // Parse pagination params
validate(req, res)        // Validate with express-validator

// Response helpers
success(res, data, 200)   // Send success response
created(res, data)        // Send 201 response
noContent(res)            // Send 204 response
error(res, message, code) // Send error response
handleError(res, error)   // Handle service errors
```

