{
  "name": "task-manager-server",
  "version": "1.0.0",
  "description": "Task Manager Server - Node.js/Express Backend API (TypeScript)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:watch": "nodemon --exec ts-node src/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run client\"",
    "client": "cd ../task-manager-client && npm run dev",
    "db:setup": "ts-node src/database/setup.ts",
    "db:setup:js": "node src/database/setup.js",
    "db:migrate": "node src/database/migrations",
    "db:migrate:maintenance": "ts-node src/database/run-maintenance-migration.ts",
    "db:seed:incoming": "ts-node src/seed-incoming-material.ts",
    "db:view:incoming": "ts-node src/view-mockup-data.ts",
    "db:health": "ts-node src/db-health-check.ts",
    "db:fix:checklist": "ts-node src/fix-checklist-form.ts",
    "db:migrate:machine-parameter-ranges": "ts-node src/database/migrations/add_machine_parameter_ranges.ts",
    "import:inspection-csv": "ts-node src/scripts/import_inspection_csv.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,json}\""
  },
  "dependencies": {
    "axios": "^1.13.3",
    "axios-cookiejar-support": "^6.0.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-validator": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "openai": "^6.15.0",
    "sql.js": "^1.11.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tough-cookie": "^6.0.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "@types/node-cron": "^3.0.11",
    "@types/sql.js": "^1.4.9",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.2",
    "sqlite3": "^5.1.7",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0"
  }
}
